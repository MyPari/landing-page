# Optional: Formspree form ID (from https://formspree.io) — enables server-side email delivery.
# Example: VITE_FORMSPREE_FORM_ID=xyzabc123
VITE_FORMSPREE_FORM_ID=

# Optional: separate Formspree form for the homepage waitlist only (stored in Formspree submissions).
# If empty, the waitlist uses VITE_FORMSPREE_FORM_ID and tags the submission as a waitlist signup.
# Example: VITE_FORMSPREE_WAITLIST_ID=abcdef123
VITE_FORMSPREE_WAITLIST_ID=

# Used in mailto fallback when Formspree is not configured
VITE_CONTACT_EMAIL=hello@mypari.com
